# ============================================================
#  SPECTER-OS — Environment Configuration
# ============================================================

# --- LLM Provider ---
# Google Gemini API key (get from https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use for attack generation & judgment
SPECTER_LLM_MODEL=gemini-2.0-flash

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./specter.db

# --- Security ---
SPECTER_SECRET_KEY=change_me_in_production_use_32chars_min

# --- Report Output ---
REPORTS_DIR=./reports

# --- Attack Config ---
# Max concurrent attack threads
MAX_CONCURRENT_ATTACKS=5
# Default timeout per attack turn (seconds)
ATTACK_TURN_TIMEOUT=30
# Max turns in a single multi-turn attack session
MAX_ATTACK_TURNS=10
